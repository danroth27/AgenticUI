<Project Sdk="Microsoft.NET.Sdk.Razor">

  <!--
    Vendored snapshot of the in-progress Blazor AI components (@javiercn, aspnetcore PR #67673).
    See NOTICE.md for provenance. Refresh via eng/sync-components-ai.ps1. The assembly name and
    namespace intentionally match the upstream package so this can be swapped for the official
    Microsoft.AspNetCore.Components.AI NuGet package with no code changes when it ships.
  -->
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);RS0016;RS0017;RS0026;RS0037;CS1591;ASP0006;CA2007;CA1852</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <PackageReference Include="Microsoft.Extensions.AI.Abstractions" Version="10.6.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Microsoft.AspNetCore.Components.AI.SourceGenerators\Microsoft.AspNetCore.Components.AI.SourceGenerators.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

</Project>
