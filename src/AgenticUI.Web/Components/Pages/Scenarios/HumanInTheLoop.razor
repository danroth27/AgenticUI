@page "/human-in-the-loop"
@inject AgentServerConnection Agents
@implements IDisposable

<PageTitle>Human in the loop</PageTitle>

<div class="scenario">
    <div class="scenario__intro">
        <h1>Human in the loop</h1>
        <p>
            The agent exposes a <code>book_meeting</code> tool wrapped in
            <code>ApprovalRequiredAIFunction</code>. Calling it raises an AG-UI interrupt; the Blazor AI
            components render Approve / Reject buttons and the run resumes only after you decide.
            Try: <em>"Book a 30 minute meeting with Sam tomorrow at 2pm."</em>
        </p>
    </div>

    <div class="scenario__chat">
        <ChatPage Agent="_agent" Placeholder="Ask me to schedule something…" />
    </div>
</div>

@code {
    private UIAgent _agent = default!;
    private IChatClient _chatClient = default!;

    protected override void OnInitialized()
    {
        _chatClient = Agents.CreateChatClient("/human_in_the_loop");
        _agent = new UIAgent(_chatClient);
    }

    public void Dispose() => (_chatClient as IDisposable)?.Dispose();
}
