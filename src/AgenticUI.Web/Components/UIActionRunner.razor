@implements IDisposable
@* Auto-invokes client-side "frontend tool" UIActionBlocks as they arrive, then lets the run resume. *@

@code {
    [CascadingParameter]
    public AgentContext Context { get; set; } = default!;

    private IDisposable? _subscription;
    private readonly HashSet<string> _invoked = new();

    protected override void OnInitialized()
    {
        _subscription = Context.RegisterOnBlockAdded((turn, block) =>
        {
            if (block is UIActionBlock action && !action.IsComplete && _invoked.Add(action.Id))
            {
                _ = InvokeAsync(async () =>
                {
                    try
                    {
                        await action.InvokeAsync();
                    }
                    catch
                    {
                        // Surfaced through the conversation status; nothing to do here.
                    }
                });
            }
        });
    }

    public void Dispose() => _subscription?.Dispose();
}
